[
  {
    "id": "1",
    "time": "00:00:00,270 --> 00:00:02,863",
    "text": "斑鸠凄苦，\n油煎豆腐。"
  },
  {
    "id": "2",
    "time": "00:00:02,864 --> 00:00:05,115",
    "text": "豆腐好吃，\n不把嫂吃。"
  },
  {
    "id": "3",
    "time": "00:00:05,353 --> 00:00:07,280",
    "text": "嫂嫂眼睛哩咕哩。"
  },
  {
    "id": "4",
    "time": "00:00:07,280 --> 00:00:09,600",
    "text": "上岭捡苦珠。"
  },
  {
    "id": "5",
    "time": "00:00:09,600 --> 00:00:11,921",
    "text": "苦珠打唛脑。"
  },
  {
    "id": "6",
    "time": "00:00:11,921 --> 00:00:13,544",
    "text": "回去学大嫂。"
  },
  {
    "id": "7",
    "time": "00:00:13,582 --> 00:00:15,050",
    "text": "回去学哥哥。"
  },
  {
    "id": "8",
    "time": "00:00:15,138 --> 00:00:16,467",
    "text": "哥哥个笔筒脑。"
  },
  {
    "id": "9",
    "time": "00:00:16,631 --> 00:00:19,656",
    "text": "回去学婆婆，\n婆婆个吹风筒脑。"
  }
]